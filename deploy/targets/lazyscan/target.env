# LazyScan deploy target config (sourced by deploy/bin/deploy.sh).
# BASE_COMPOSE is relative to each checkout; CHECKOUT_* are VPS paths.
# Interpolation/secrets come from each checkout's own .env, not from here.
BASE_COMPOSE="docker-compose.yml"
CHECKOUT_PROD="/opt/lazyscan-prod"
CHECKOUT_STAGING="/opt/lazyscan-staging"
